{
  "title": "Bigger states have more unactivated premises",
  "width": 620,
  "height": 360,
  "data": {
    "url": "data/nbn_state_jan2025.csv"
  },
  "mark": {
    "type": "circle",
    "opacity": 0.75
  },
  "encoding": {
    "x": {
      "field": "total_ready",
      "type": "quantitative",
      "title": "Ready to connect",
      "axis": {
        "format": "~s"
      }
    },
    "y": {
      "field": "total_activated",
      "type": "quantitative",
      "title": "Activated",
      "axis": {
        "format": "~s"
      }
    },
    "size": {
      "field": "satellite_ready",
      "title": "Satellite-ready premises"
    },
    "color": {
      "field": "activation_rate",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Activated %"
    },
    "tooltip": [
      "state",
      {
        "field": "total_ready",
        "format": ","
      },
      {
        "field": "total_activated",
        "format": ","
      },
      {
        "field": "satellite_ready",
        "format": ","
      },
      "activation_rate"
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "anchor": "start"
    }
  }
}