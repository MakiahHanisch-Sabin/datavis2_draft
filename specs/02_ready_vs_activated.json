{
  "title": "Ready-to-connect premises: active vs waiting",
  "width": 620,
  "height": 300,
  "data": {
    "url": ".data/nbn_state_jan2025.csv"
  },
  "transform": [
    {
      "fold": [
        "total_activated",
        "not_activated"
      ],
      "as": [
        "Status",
        "Premises"
      ]
    },
    {
      "calculate": "datum.Status == \"total_activated\" ? \"Activated\" : \"Ready but not active\"",
      "as": "StatusLabel"
    }
  ],
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "state",
      "sort": "-y",
      "title": "State"
    },
    "y": {
      "field": "Premises",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "format": "%"
      }
    },
    "color": {
      "field": "StatusLabel",
      "scale": {
        "range": [
          "#2f6f9f",
          "#d8e6f3"
        ]
      }
    },
    "tooltip": [
      "state",
      "StatusLabel",
      {
        "field": "Premises",
        "format": ","
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "anchor": "start"
    }
  }
}