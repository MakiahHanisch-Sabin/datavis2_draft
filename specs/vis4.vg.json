{
  "title": "Access technology mix behind ready premises",
  "width": 620,
  "height": 330,
  "data": {
    "url": "data/nbn_technology_ready_long.csv"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "state",
      "title": "State"
    },
    "y": {
      "field": "Ready",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "format": "%"
      }
    },
    "color": {
      "field": "Technology",
      "scale": {
        "range": [
          "#1f77b4",
          "#ff9f1c",
          "#6a4c93"
        ]
      }
    },
    "tooltip": [
      "state",
      "Technology",
      {
        "field": "Ready",
        "format": ","
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "anchor": "start"
    }
  }
}