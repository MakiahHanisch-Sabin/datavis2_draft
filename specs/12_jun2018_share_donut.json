{
  "title": "June 2018 download share by connection type",
  "width": 360,
  "height": 300,
  "data": {
    "url": ".data/download_tb_long.csv"
  },
  "transform": [
    {
      "filter": "datum.Period == \"Jun 2018\" && datum.Connection != \"Total\""
    }
  ],
  "mark": {
    "type": "arc",
    "innerRadius": 70
  },
  "encoding": {
    "theta": {
      "field": "Terabytes",
      "type": "quantitative"
    },
    "color": {
      "field": "Connection",
      "scale": {
        "range": [
          "#2f6f9f",
          "#ff9f1c"
        ]
      }
    },
    "tooltip": [
      "Connection",
      {
        "field": "Terabytes",
        "format": ","
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "anchor": "start"
    }
  }
}