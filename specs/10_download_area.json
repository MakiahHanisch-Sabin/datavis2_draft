{
  "title": "Fixed line carried almost all downloaded data",
  "width": 620,
  "height": 300,
  "data": {
    "url": ".data/download_tb_long.csv"
  },
  "transform": [
    {
      "filter": "datum.Connection != \"Total\""
    }
  ],
  "mark": "area",
  "encoding": {
    "x": {
      "field": "PeriodDate",
      "type": "temporal"
    },
    "y": {
      "field": "Terabytes",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "format": "%"
      }
    },
    "color": {
      "field": "Connection",
      "scale": {
        "range": [
          "#2f6f9f",
          "#ff9f1c"
        ]
      }
    },
    "tooltip": [
      "Period",
      "Connection",
      {
        "field": "Terabytes",
        "format": ","
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "anchor": "start"
    }
  }
}