{
  "title": "Where the nbn network is most activated",
  "width": 620,
  "height": 380,
  "projection": {
    "type": "equirectangular"
  },
  "data": {
    "url": "https://vega.github.io/vega-datasets/data/australia-states.json",
    "format": {
      "type": "topojson",
      "feature": "australia-states"
    }
  },
  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {
          "url": "data/nbn_state_jan2025.csv"
        },
        "key": "state_name",
        "fields": [
          "activation_rate",
          "total_ready",
          "total_activated"
        ]
      }
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "color": {
      "field": "activation_rate",
      "type": "quantitative",
      "title": "Activated (%)",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "properties.STATE_NAME",
        "title": "State"
      },
      {
        "field": "activation_rate",
        "title": "Activated %"
      },
      {
        "field": "total_ready",
        "format": ","
      },
      {
        "field": "total_activated",
        "format": ","
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "anchor": "start"
    }
  }
}