{
  "title": "How close 2022 measured speeds were to advertised plan speeds",
  "width": 620,
  "height": 300,
  "data": {
    "url": ".data/speed_by_plan.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "color": "#d8e6f3"
      },
      "encoding": {
        "y": {
          "field": "Plan",
          "sort": "-x"
        },
        "x": {
          "field": "Advertised",
          "title": "Mbps"
        }
      }
    },
    {
      "mark": {
        "type": "bar",
        "color": "#2f6f9f",
        "height": 12
      },
      "encoding": {
        "y": {
          "field": "Plan",
          "sort": "-x"
        },
        "x": {
          "field": "2022",
          "title": "Mbps"
        },
        "tooltip": [
          "Plan",
          "2022",
          "Advertised"
        ]
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "anchor": "start"
    }
  }
}